# Copy this to .env and fill in your API keys
# On Railway/Render, set these as environment variables in the dashboard.

# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Required: Tavily API key for web search (free tier available)
# Get one at: https://tavily.com/
TAVILY_API_KEY=your-tavily-api-key-here

# Optional: Firecrawl API key for better web scraping
# Get one at: https://firecrawl.dev/
FIRECRAWL_API_KEY=your-firecrawl-api-key-here

# ---------------------------------------------------------------------------
# Web App Settings (only needed for deployed web version)
# ---------------------------------------------------------------------------

# Optional: Resend API key for email delivery
# Get one at: https://resend.com/ (free tier: 3,000 emails/month)
RESEND_API_KEY=your-resend-api-key-here

# The "from" address for emails.
# IMPORTANT: 'onboarding@resend.dev' is the Resend sandbox — it can ONLY send to
# the account owner's email. To send to any recipient, verify your own domain at
# https://resend.com/domains and use that domain here.
FROM_EMAIL=SEED Research <research@yourdomain.com>

# CC recipients — comma-separated list of emails that receive a copy of every delivery.
# Leave blank to disable CC.
CC_EMAILS=

# Optional: Access code to restrict who can run research (leave blank to disable)
ACCESS_CODE=

# Auth credentials for web login (defaults: admin / seedresearch)
AUTH_USERNAME=admin
AUTH_PASSWORD=seedresearch

# Public base URL for results links in emails (set after deploy)
BASE_URL=http://localhost:8080
